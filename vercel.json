{
  "outputDirectory": ".",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.metrixrealty.com" }],
      "destination": "https://metrixrealty.com/:path*",
      "permanent": true
    },
    { "source": "/services-enhanced.html", "destination": "/services", "permanent": true },
    { "source": "/services-enhanced", "destination": "/services", "permanent": true },
    { "source": "/contact-enhanced.html", "destination": "/contact", "permanent": true },
    { "source": "/contact-enhanced", "destination": "/contact", "permanent": true },
    { "source": "/market-insights.html", "destination": "/insights/", "permanent": true },
    { "source": "/market-insights", "destination": "/insights/", "permanent": true },
    { "source": "/services/index.html", "destination": "/services", "permanent": true },
    { "source": "/services/index", "destination": "/services", "permanent": true },
    { "source": "/windsor", "destination": "/windsor/", "permanent": true },
    { "source": "/london", "destination": "/london/", "permanent": true },
    { "source": "/insights/appraisal-vs-realtor-cma-ontario.html", "destination": "/insights/appraisal-vs-realtor-cma-ontario/", "permanent": true },
    { "source": "/insights/bank-appraisal-vs-private-appraisal-ontario.html", "destination": "/insights/bank-appraisal-vs-private-appraisal-ontario/", "permanent": true },
    { "source": "/insights/listing-prices-misconception.html", "destination": "/insights/listing-prices-misconception/", "permanent": true },
    { "source": "/insights/ontario-market-analysis-2016-2024.html", "destination": "/insights/ontario-market-analysis-2016-2024/", "permanent": true },
    { "source": "/insights/sentimental-equity-problem.html", "destination": "/insights/sentimental-equity-problem/", "permanent": true },
    { "source": "/insights/what-is-aaci-designation.html", "destination": "/insights/what-is-aaci-designation/", "permanent": true },
    { "source": "/insights/what-is-cuspap.html", "destination": "/insights/what-is-cuspap/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ]
}
